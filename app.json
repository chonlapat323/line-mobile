{
  "expo": {
    "name": "BeautyUp Sales",
    "slug": "line-sender-mobile",
    "version": "2.1.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "linesender",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beautyup.linesender"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.beautyup.linesender",
      "versionCode": 6,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BeautyUp Sales to access your photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "164a363d-5ddb-4197-9383-86743c42bf4b"
      }
    },
    "owner": "saberakito"
  }
}
